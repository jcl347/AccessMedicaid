{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/innetwork.js": { "includeFiles": "data/**", "maxDuration": 30 }
  },
  "crons": [
    { "path": "/api/verify", "schedule": "0 13 * * 1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
